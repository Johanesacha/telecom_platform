# --- Application ---
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
PROJECT_NAME=Telecom API Platform
API_VERSION=1.0.0

# --- Database (Async - pour FastAPI) ---
DATABASE_URL=postgresql+asyncpg://telecom:telecom_dev_password@localhost:5432/telecom_db

# --- Database (Sync - pour Celery) ---
SYNC_DATABASE_URL=postgresql+psycopg2://telecom:telecom_dev_password@localhost:5432/telecom_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- JWT (RS256) ---
JWT_PRIVATE_KEY_PATH=./jwt_private.pem
JWT_PUBLIC_KEY_PATH=./jwt_public.pem
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Rate Limiting ---
RATE_LIMIT_BURST_FREE=10
RATE_LIMIT_BURST_STANDARD=60
RATE_LIMIT_BURST_PREMIUM=500
RATE_LIMIT_BURST_SANDBOX=120

# --- Quota (appels journaliers) ---
QUOTA_FREE_SMS=100
QUOTA_FREE_PAYMENTS=20
QUOTA_STANDARD_SMS=1000
QUOTA_STANDARD_PAYMENTS=200
QUOTA_PREMIUM_SMS=10000
QUOTA_PREMIUM_PAYMENTS=2000

# --- USSD ---
USSD_SESSION_TTL_SECONDS=180

# --- Admin initial ---
INITIAL_ADMIN_EMAIL=admin@telecom.sn
INITIAL_ADMIN_PASSWORD=CHANGE_ME_BEFORE_USE